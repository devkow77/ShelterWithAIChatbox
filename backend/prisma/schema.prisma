generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ROLE {
  UŻYTKOWNIK
  PRACOWNIK
  ADMINISTRATOR
}

enum AnimalStatus {
  SZUKA_DOMU
  ZNALEZIONY
  W_TRAKCIE_ADOPCJI
  ADOPTOWANY
}

model User {
  id        Int      @id @default(autoincrement())
  fullName  String
  email     String   @unique
  password  String
  role      ROLE     @default(UŻYTKOWNIK)

  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Animal {
  id          Int           @id @default(autoincrement())
  name        String
  type        String
  gender      String
  size        String
  traits      String
  age         Int
  description String

  status      AnimalStatus  @default(ZNALEZIONY)
  foundAt     DateTime?     
  foundLocation String?     
  availableFrom DateTime?   

  imageUrl        String[]
}
