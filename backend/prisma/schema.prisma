generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ROLE {
  USER
  WORKER
  ADMIN
}

enum AnimalStatus {
  FOUND       // znaleziony - szukamy właściciela
  AVAILABLE   // do adopcji
  ADOPTED     // adoptowany
}

model User {
  id        Int      @id @default(autoincrement())
  fullName  String
  email     String   @unique
  password  String
  role      ROLE     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Animal {
  id          Int           @id @default(autoincrement())
  slug        String        @unique
  name        String
  type        String
  gender      String
  size        String
  traits      String[]
  age         Int
  img         String
  description String

  status      AnimalStatus  @default(FOUND)
  foundAt     DateTime?     // kiedy znaleziony
  foundLocation String?     // gdzie znaleziony
  availableFrom DateTime?   // od kiedy do adopcji

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}