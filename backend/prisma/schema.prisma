generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ROLE{
  USER
  WORKER
  ADMIN
}

model User {
  id        Int      @id @default(autoincrement())
  fullName  String
  email     String   @unique
  password  String
  role      ROLE     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Animal{
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  name        String
  type        String
  gender      String
  size        String
  traits      String[]
  age         Int
  img         String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
